{
  "name": "map",
  "version": "0.1.1",
  "description": "Local-first couple memory map desktop app",
  "author": "Map for Love",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "dev:keepalive": "bash scripts/dev-keepalive.sh",
    "dev:daemon": "bash scripts/start-dev-daemon.sh",
    "build": "next build",
    "build:mobile": "node scripts/build-mobile.mjs",
    "desktop:prepare": "npm run build && node scripts/prepare-standalone.mjs",
    "preview": "next start",
    "start": "next start",
    "lint": "eslint",
    "desktop": "electron electron/main.js",
    "dist:dir": "npm run desktop:prepare && electron-builder --dir",
    "dist:mac": "npm run desktop:prepare && electron-builder --mac dmg",
    "dist:win": "npm run desktop:prepare && electron-builder --win nsis --x64",
    "cap:open": "npx cap open android"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.mapofus.desktop",
    "productName": "Map for Love",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "npmRebuild": false,
    "afterPack": "./scripts/after-pack.cjs",
    "files": [
      "!node_modules/**/*",
      "electron/**/*",
      ".next/standalone/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.lifestyle",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-${arch}-Setup.${ext}"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@supabase/supabase-js": "^2.106.0",
    "ali-oss": "^6.23.0",
    "d3-geo": "^3.1.1",
    "exifr": "^7.1.3",
    "framer-motion": "^12.39.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "proxy-agent": "^5.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/ali-oss": "^6.23.3",
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
